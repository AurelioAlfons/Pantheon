# --- core ---
MODE=demo                          # demo | personal -- drives the credential checks below and everything downstream
AGENT_CONFIG_DIR=./agents          # relative paths get anchored to the repo root, not wherever the process runs from

# --- database ---
DATABASE_URL=                      # supabase postgres connection string
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=              # personal mode only -- this one should never reach the frontend

# --- integrations (personal mode only, keep blank in demo) ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- demo protections (demo mode only) ---
RATE_LIMIT_PER_MINUTE=10
DEMO_MAX_TASKS_PER_SESSION=5

# --- personal instance auth ---
ADMIN_PASSWORD_HASH=               # bcrypt hash, personal mode only
SESSION_SECRET=

# --- task-chain safety (both modes) ---
MAX_TASK_CHAIN_DEPTH=10            # hard cap so agent-to-agent task spawning can't loop forever
